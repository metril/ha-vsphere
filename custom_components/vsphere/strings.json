    "services": {
        "vm_power": {
            "name": "VM Power Control",
            "description": "Control the power state of a virtual machine.",
            "fields": {
                "device_id": { "name": "Device", "description": "The virtual machine to control." },
                "action": {
                    "name": "Action",
                    "description": "Power action to perform.",
                    "selector": {
                        "select": {
                            "options": {
                                "power_on": "Power on",
                                "power_off": "Power off",
                                "shutdown": "Guest shutdown",
                                "reboot": "Guest reboot",
                                "reset": "Hard reset",
                                "suspend": "Suspend"
                            }
                        }
                    }
                }
            }
        },
        "host_power": {
            "name": "Host Power Control",
            "description": "Shutdown or reboot an ESXi host.",
            "fields": {
                "device_id": { "name": "Device", "description": "The ESXi host." },
                "action": {
                    "name": "Action",
                    "description": "Power action to perform on the host.",
                    "selector": {
                        "select": {
                            "options": { "shutdown": "Shutdown", "reboot": "Reboot" }
                        }
                    }
                },
                "force": { "name": "Force", "description": "Force the action even if VMs are running." }
            }
        },
        "host_power_policy": {
            "name": "Host Power Policy",
            "description": "Set the power management policy for an ESXi host.",
            "fields": {
                "device_id": { "name": "Device", "description": "The ESXi host." },
                "policy": { "name": "Policy", "description": "Power management policy key (use list_power_policies to discover values)." }
            }
        },
        "host_maintenance_mode": {
            "name": "Host Maintenance Mode",
            "description": "Enable or disable maintenance mode on an ESXi host.",
            "fields": {
                "device_id": { "name": "Device", "description": "The ESXi host." },
                "enable": { "name": "Enable", "description": "Enter maintenance mode when on, exit when off." }
            }
        },
        "create_snapshot": {
            "name": "Create VM Snapshot",
            "description": "Create a snapshot of a virtual machine.",
            "fields": {
                "device_id": { "name": "Device", "description": "The virtual machine." },
                "name": { "name": "Name", "description": "Snapshot name (optional)." },
                "description": { "name": "Description", "description": "Snapshot description (optional)." },
                "memory": { "name": "Include memory", "description": "Include the VM's memory state in the snapshot." },
                "quiesce": { "name": "Quiesce filesystem", "description": "Quiesce guest filesystem before snapshotting." }
            }
        },
        "remove_snapshot": {
            "name": "Remove VM Snapshot",
            "description": "Remove one or all snapshots from a virtual machine.",
            "fields": {
                "device_id": { "name": "Device", "description": "The virtual machine." },
                "which": {
                    "name": "Which",
                    "description": "Which snapshot to remove.",
                    "selector": {
                        "select": {
                            "options": { "all": "All", "first": "First", "last": "Last" }
                        }
                    }
                }
            }
        },
        "remove_snapshots": {
            "name": "Remove Snapshots",
            "description": "Remove one or more snapshots from a virtual machine by name. Pass \"all\" to remove all snapshots.",
            "fields": {
                "device_id": { "name": "VM", "description": "The virtual machine to remove snapshots from." },
                "snapshots": { "name": "Snapshots", "description": "List of snapshot names to remove. Use \"all\" to remove all snapshots." }
            }
        },
        "list_hosts": {
            "name": "List Hosts",
            "description": "Return a list of all ESXi hosts managed by this vSphere connection.",
            "fields": {
                "device_id": { "name": "Device", "description": "Any device belonging to the vSphere connection." }
            }
        },
        "list_power_policies": {
            "name": "List Power Policies",
            "description": "Return the available power management policies for an ESXi host.",
            "fields": {
                "device_id": { "name": "Device", "description": "The ESXi host." }
            }
        },
        "vm_migrate": {
            "name": "VM Migration (vMotion)",
            "description": "Live-migrate a virtual machine to a different host.",
            "fields": {
                "device_id": { "name": "VM", "description": "The virtual machine to migrate." },
                "target_host": { "name": "Target Host", "description": "The destination ESXi host device." }
            }
        }
