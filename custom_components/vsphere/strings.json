    "config": {
        "step": {
            "user": {
                "title": "vSphere Connection",
                "description": "Enter your vCenter or ESXi host credentials.",
                "data": {
                    "host": "Host",
                    "port": "Port",
                    "username": "Username",
                    "password": "Password"
                },
                "data_description": {
                    "host": "IP address or hostname of your vCenter or ESXi server",
                    "port": "Usually 443 for HTTPS connections",
                    "username": "For vCenter use user@domain.com format. For ESXi use local account name (e.g., root)",
                    "password": "Your vSphere account password"
                },
                "sections": {
                    "ssl_options": {
                        "name": "SSL / Certificate Options",
                        "data": {
                            "verify_ssl": "Verify SSL certificate",
                            "ssl_ca_path": "CA certificate path"
                        },
                        "data_description": {
                            "verify_ssl": "Enable to verify the server's SSL certificate. Disable for self-signed certificates",
                            "ssl_ca_path": "Path to a PEM-encoded CA certificate file on the HA host (e.g., /ssl/vsphere-ca.pem). Only needed with a private/internal CA"
                        }
                    }
                }
            },
            "categories": {
                "title": "Monitoring Categories",
                "sections": {
                    "core_categories": {
                        "name": "Core Monitoring",
